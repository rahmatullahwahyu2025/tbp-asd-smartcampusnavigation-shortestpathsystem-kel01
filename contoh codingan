# --- Edge berbobot acak (Menggunakan Bawaan Python 'random') ---
def generate_edges(nodes, seed=7):
    random.seed(seed)
    n = len(nodes)
    edges = []
    
    indices = list(range(n))
    random.shuffle(indices)
    
    for i in range(1, n):
        u = nodes[indices[i-1]][0]
        v = nodes[indices[i]][0]
        w = random.randint(50, 500)
        edges.append((u, v, w))
    
    extra = int(n * 0.8) 
    for _ in range(extra):
        i, j = random.sample(range(n), 2)
        w = random.randint(50, 500)
        edges.append((nodes[i][0], nodes[j][0], w))
    return edges

# --- Struktur Data Pendukung (Queue & Stack Linked List) ---
class NodeLL:
    def __init__(self, data):
        self.data = data
        self.next = None

class QueueLL:
    def __init__(self):
        self.head = None
        self.tail = None

    def enqueue(self, data):
        new_node = NodeLL(data)
        if not self.tail:
            self.head = new_node
            self.tail = new_node
            return
        self.tail.next = new_node
        self.tail = new_node

    def dequeue(self):
        if not self.head:
            return None
        temp = self.head
        self.head = self.head.next
        if not self.head:
            self.tail = None
        return temp.data

    def is_empty(self):
        return self.head is None

class StackLL:
    def __init__(self):
        self.top = None

    def push(self, data):
        new_node = NodeLL(data)
        new_node.next = self.top
        self.top = new_node

    def pop(self):
        if not self.top:
            return None
        temp = self.top
        self.top = self.top.next
        return temp.data

    def is_empty(self):
        return self.top is None

# --- Graph (Adjacency List dengan Linked List) ---
class EdgeNode:
    def __init__(self, dest: str, bobot: int):
        self.dest = dest
        self.bobot = bobot
        self.next: Optional['EdgeNode'] = None

class Graph:
    def __init__(self):
        self.adj: Dict[str, Optional[EdgeNode]] = {}
        self.node_names: Dict[str, str] = {}

    def add_node(self, node_id: str, nama: str) -> None:
        if node_id not in self.adj:
            self.adj[node_id] = None
            self.node_names[node_id] = nama

    def add_edge(self, u: str, v: str, bobot: int) -> None:
        new_node_v = EdgeNode(v, bobot)
        new_node_v.next = self.adj[u]
        self.adj[u] = new_node_v

        new_node_u = EdgeNode(u, bobot)
        new_node_u.next = self.adj[v]
        self.adj[v] = new_node_u

    def neighbors(self, u: str) -> List[Tuple[str, int]]:
        res = []
        curr = self.adj.get(u)
        while curr:
            res.append((curr.dest, curr.bobot))
            curr = curr.next
        return res

# --- Algoritma Navigasi ---
def dijkstra(graph: Graph, source: str) -> Tuple[Dict[str, int], Dict[str, Optional[str]]]:
    INF = float('inf')
    dist = {v: INF for v in graph.adj}
    parent = {v: None for v in graph.adj}
    visited = set()
    dist[source] = 0

    for _ in range(len(graph.adj)):
        u = None
        min_dist = INF
        for v in graph.adj:
            if v not in visited and dist[v] < min_dist:
                min_dist = dist[v]
                u = v
        
        if u is None:
            break
            
        visited.add(u)
        curr = graph.adj[u]
        
        while curr:
            v = curr.dest
            w = curr.bobot
            if dist[u] + w < dist[v]:
                dist[v] = dist[u] + w
                parent[v] = u
            curr = curr.next
            
    return dist, parent

def reconstruct_path(parent: Dict[str, Optional[str]], source: str, target: str) -> List[str]:
    path = []
    curr = target
    while curr is not None:
        path.append(curr)
        if curr == source:
            break
        curr = parent[curr]
    
    if path and path[-1] == source:
        return path[::-1]
    return []

def bfs(graph: Graph, source: str) -> List[str]:
    visited = {source}
    queue = QueueLL()
    queue.enqueue(source)
    order = []
    while not queue.is_empty():
        u = queue.dequeue()
        order.append(u)
        curr = graph.adj[u]
        while curr:
            if curr.dest not in visited:
                visited.add(curr.dest)
                queue.enqueue(curr.dest)
            curr = curr.next
    return order

def dfs(graph: Graph, source: str) -> List[str]:
    visited = {source}
    stack = StackLL()
    stack.push(source)
    order = []
    while not stack.is_empty():
        u = stack.pop()
        order.append(u)
        curr = graph.adj[u]
        while curr:
            if curr.dest not in visited:
                visited.add(curr.dest)
                stack.push(curr.dest)
            curr = curr.next
    return order

# --- BST Direktori Gedung ---
class BSTNode:
    def __init__(self, key: str, nama: str):
        self.key = key
        self.nama = nama
        self.left: Optional['BSTNode'] = None
        self.right: Optional['BSTNode'] = None

class BSTGedung:
    def __init__(self):
        self.root: Optional[BSTNode] = None

    def insert(self, key: str, nama: str) -> None:
        if not self.root:
            self.root = BSTNode(key, nama)
            return
        curr = self.root
        while True:
            if key < curr.key:
                if curr.left:
                    curr = curr.left
                else: 
                    curr.left = BSTNode(key, nama)
                    break
            elif key > curr.key:
                if curr.right:
                    curr = curr.right
                else:
                    curr.right = BSTNode(key, nama)
                    break
            else:
                break

    def search(self, key: str) -> Optional[str]:
        curr = self.root
        while curr:
            if key == curr.key:
                return curr.nama
            if key < curr.key:
                curr = curr.left
            else:
                curr = curr.right
        return None

    def inorder(self) -> List[Tuple[str, str]]:
        res = []
        stack = StackLL()
        curr = self.root
        while not stack.is_empty() or curr:
            if curr:
                stack.push(curr)
                curr = curr.left
            else:
                curr = stack.pop()
                res.append((curr.key, curr.nama))
                curr = curr.right
        return res

