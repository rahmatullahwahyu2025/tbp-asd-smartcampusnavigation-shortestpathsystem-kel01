# --- Main CLI ---
def main():
    g = Graph()
    bst = BSTGedung()
    
    for gid, gname in GEDUNG_DATA:
        g.add_node(gid, gname)
        bst.insert(gid, gname)
    
    edges = generate_edges(GEDUNG_DATA, seed=7)
    for u, v, w in edges:
        g.add_edge(u, v, w)
    
    print('Smart Campus Navigation System. Ketik BANTUAN untuk daftar perintah')
    
    while True:
        try:
            line = input("\n> ").strip().split()
            if not line: continue
            cmd = line[0].upper()

            if cmd == "BANTUAN":
                print("Perintah: TAMBAH_GEDUNG <id> <nama>, TAMBAH_JALAN <u> <v> <w>, JALUR <asal> <tujuan>,")
                print("JELAJAH_DFS <id>, JELAJAH_BFS <id>, CARI_GEDUNG <id>, TERISOLASI, LAPORAN_GRAPH, KELUAR")

            elif cmd == "TAMBAH_GEDUNG" and len(line) >= 3:
                gid, gname = line[1], " ".join(line[2:])
                g.add_node(gid, gname)
                bst.insert(gid, gname)
                print(f"Gedung {gid} ({gname}) ditambahkan. Big-O: O(log V) BST, O(1) Graph")

            elif cmd == "TAMBAH_JALAN" and len(line) == 4:
                u, v, w = line[1], line[2], int(line[3])
                g.add_edge(u, v, w)
                print(f"Jalan {u}-{v} jarak {w}m ditambahkan. Big-O: O(1)")
            
            elif cmd == "KELUAR":
                print("Keluar dari program. Terima kasih!")
                break
            
            else:
                print("Perintah tidak dikenali. Ketik BANTUAN untuk melihat daftar perintah.")

        # Menambahkan blok except yang diminta oleh Python
        except ValueError:
            print("Error: Format angka salah (misalnya jarak jalan harus berupa angka).")
        except (KeyboardInterrupt, EOFError):
            print("\nProgram dihentikan secara paksa.")
            break
        except Exception as e:
            print(f"Terjadi kesalahan: {e}")

if __name__ == "__main__":
    main()
